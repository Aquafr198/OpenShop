{
  "name": "@openshop/example-node-storefront",
  "version": "0.0.0",
  "private": true,
  "description": "A zero-config example storefront wiring all OpenShop modules together.",
  "type": "module",
  "scripts": {
    "start": "node --import tsx src/server.ts",
    "dev": "node --watch --import tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openshop/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
