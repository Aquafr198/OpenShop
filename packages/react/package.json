{
  "name": "@openshop/react",
  "version": "0.10.0",
  "description": "React bindings for OpenShop's framework-agnostic commerce core.",
  "license": "MIT",
  "author": "Aquafr198",
  "homepage": "https://github.com/Aquafr198/OpenShop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aquafr198/OpenShop.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Aquafr198/OpenShop/issues"
  },
  "keywords": [
    "shopify",
    "headless",
    "commerce",
    "storefront",
    "react",
    "ecommerce",
    "hydrogen",
    "cart"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@openshop/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "happy-dom": "^15.11.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
