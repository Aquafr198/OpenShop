{
  "name": "@openshop/svelte",
  "version": "0.5.0",
  "description": "Svelte stores for OpenShop's framework-agnostic commerce core.",
  "license": "MIT",
  "author": "Aquafr198",
  "homepage": "https://github.com/Aquafr198/OpenShop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aquafr198/OpenShop.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/Aquafr198/OpenShop/issues"
  },
  "keywords": [
    "shopify",
    "headless",
    "commerce",
    "storefront",
    "svelte",
    "ecommerce",
    "hydrogen",
    "cart"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "dependencies": {
    "@openshop/core": "workspace:*"
  },
  "devDependencies": {
    "svelte": "^5.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
